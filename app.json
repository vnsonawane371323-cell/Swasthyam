        "icon": "./assets/notification-icon.png",
        "color": "#1b4a5a"
      },
      "package": "com.swasthtel.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "googleExpoClientId": "146026611863-3esg5l9cq4bhb2gs8lg0k59pjfeh44de.apps.googleusercontent.com",
      "googleWebClientId": "146026611863-3esg5l9cq4bhb2gs8lg0k59pjfeh44de.apps.googleusercontent.com",
      "googleAndroidClientId": "146026611863-oo8qkplc96a3fma96v029qnrioais177.apps.googleusercontent.com",
      "googleRedirectUri": "https://auth.expo.io/@Swasthyam-1111/swasthtel-app",
      "googleProjectNameForProxy": "@Swasthyam-1111/swasthtel-app",
      "eas": {
        "projectId": "705dcefc-4c18-4ae6-8f60-669adec47c52"
